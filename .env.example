# =========================
# CTDT AI Server — cấu hình mẫu
# Sao chép thành .env và điền giá trị thực
# =========================

# APP
APP_NAME="CTDT AI Server"
ENV=production

# DATABASE (PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ctdt_ai

# AUTH / JWT
JWT_SECRET=<generate with: openssl rand -hex 32>
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=3600

# OPENAI (not required for local/dev core RAG with EMBEDDING_PROVIDER=local)
OPENAI_API_KEY=

# EMBEDDING
# local is deterministic and suitable for local/dev. Use openai only when
# enabling external embedding calls and setting OPENAI_API_KEY.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=128
EMBEDDING_BATCH_SIZE=32

# VECTOR INDEX
# pgvector = real RAG retrieval mode. null = no-vector mode only, not full RAG.
VECTOR_INDEX=pgvector

# POSTGRES FULL-TEXT SEARCH
# Vietnamese CTDT documents should use simple unless a specific indexed config is added.
POSTGRES_FTS_CONFIG=simple

# LLM ANSWER
LLM_ANSWER_ENABLED=false
LLM_ANSWER_PROVIDER=openai
LLM_ANSWER_MODEL=gpt-4o-mini
LLM_ANSWER_TIMEOUT_S=25
LLM_ANSWER_MAX_TOKENS=600
LLM_ANSWER_TEMPERATURE=0.2

# LLM QUERY PLANNER
LLM_QUERY_PLANNER_ENABLED=false
LLM_QUERY_PLANNER_PROVIDER=openai
LLM_QUERY_PLANNER_MODEL=gpt-4.1-mini

# DOCUMENT SYNTHESIS
SYNTHESIS_ENABLED=false
SYNTHESIS_MODEL=gpt-4o-mini

# QUERY REWRITE
QUERY_REWRITE_ENABLED=false
QUERY_REWRITE_PROVIDER=openai
QUERY_REWRITE_MODEL=gpt-4o-mini

# METADATA-AWARE RETRIEVAL
METADATA_RETRIEVAL_ENABLED=true

# REPRESENTATION POLICY
REPRESENTATION_POLICY_ENABLED=true

# DOCUMENT INGEST
DOCUMENT_INGEST_MODE=semantic

# REMOTE FILE INGEST
# Comma-separated FileServer host allowlist for CTDT ingest URLs.
RAG_REMOTE_FILE_ALLOWED_HOSTS=fileserver.local,files.example.edu.vn

# MOODLE INTEGRATION (CTDT)
# Lấy token tại: Moodle Admin > Site administration > Server > Web services > Manage tokens
MOODLE_BASE_URL=https://moodle.youruniversity.edu.vn
MOODLE_WSTOKEN=your_moodle_webservice_token_here
MOODLE_TIMEOUT_S=10.0
